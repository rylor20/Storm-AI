{
  "version": 2,
  "builds": [
    {
      "src": "*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/chat.js" },
    { "src": "/api/config.js", "dest": "/config.js" },
    { "src": "/api/deobfuscate", "dest": "/deobfuscate.js" },
    { "src": "/api/get-actions", "dest": "/get-actions.js" },
    { "src": "/api/pusher-auth", "dest": "/pusher-auth.js" },
    { "src": "/api/report-error", "dest": "/report-error.js" },
    { "src": "/api/reupload-assets", "dest": "/reupload-assets.js" },
    { "src": "/api/scan-assets", "dest": "/scan-assets.js" },
    { "src": "/api/search-roblox", "dest": "/search-roblox.js" },
    { "src": "/api/sync-tree", "dest": "/sync-tree.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
